# Copy this file to .env. Never commit .env.
OCI_REGION=eu-frankfurt-1
OCI_CONFIG_FILE=/absolute/path/to/.oci/config
OCI_CONFIG_PROFILE=DEFAULT
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..xxxxx
OCI_TENANCY_ID=ocid1.tenancy.oc1..xxxxx
# Required only when enabling the OCI Object Storage Longhorn backup module.
OCI_LONGHORN_BACKUP_USER_EMAIL=backup-contact@example.com
# Required when enabling the central OCI-backed Mimir storage module.
OCI_MIMIR_STORAGE_USER_EMAIL=mimir-storage-contact@example.com

# Select one of the Terragrunt stacks under live/oci/clusters.
# CLUSTER_NAME=tools

# These are consumed by OpenTofu automatically.
TF_VAR_kubernetes_version=v1.36.1
TF_VAR_worker_shape=VM.Standard.E2.1
TF_VAR_worker_image_pattern=Oracle-Linux-9.7-2026.06.15
TF_VAR_ssh_public_key=ssh-ed25519 AAAA...

# Required when deploying staging or production configuration. The tools stack
# creates a Vault and key automatically if this is left unset.
# TF_VAR_vault_id=ocid1.vault.oc1...
# TF_VAR_github_app_id=123456
# TF_VAR_github_app_installation_id=12345678
# TF_VAR_github_app_pem='-----BEGIN PRIVATE KEY-----...'
# TF_VAR_gh_token=github_pat_...
