  "panels": [
    {"type":"stat","title":"Clusters reporting","gridPos":{"h":4,"w":6,"x":0,"y":0},"datasource":{"type":"prometheus","uid":"mimir"},"targets":[{"expr":"count(count by (cluster) (up{environment=~\"$environment\",cluster=~\"$cluster\"}))","refId":"A"}]},
    {"type":"stat","title":"Nodes up","gridPos":{"h":4,"w":6,"x":6,"y":0},"datasource":{"type":"prometheus","uid":"mimir"},"targets":[{"expr":"sum(kube_node_status_condition{environment=~\"$environment\",cluster=~\"$cluster\",condition=\"Ready\",status=\"true\"})","refId":"A"}]},
    {"type":"stat","title":"Pods not running","gridPos":{"h":4,"w":6,"x":12,"y":0},"datasource":{"type":"prometheus","uid":"mimir"},"targets":[{"expr":"sum(kube_pod_status_phase{environment=~\"$environment\",cluster=~\"$cluster\",namespace=~\"$namespace\",phase=~\"Pending|Failed|Unknown\"})","refId":"A"}]},
    {"type":"stat","title":"Remote-write samples/sec","gridPos":{"h":4,"w":6,"x":18,"y":0},"datasource":{"type":"prometheus","uid":"mimir"},"targets":[{"expr":"sum(rate(prometheus_remote_storage_samples_total{environment=~\"$environment\",cluster=~\"$cluster\"}[5m]))","refId":"A"}]},
    {"type":"timeseries","title":"CPU usage by cluster","gridPos":{"h":8,"w":12,"x":0,"y":4},"datasource":{"type":"prometheus","uid":"mimir"},"targets":[{"expr":"sum(rate(node_cpu_seconds_total{environment=~\"$environment\",cluster=~\"$cluster\",mode!=\"idle\"}[5m])) by (cluster)","legendFormat":"{{cluster}}","refId":"A"}]},
    {"type":"timeseries","title":"Memory usage by cluster","gridPos":{"h":8,"w":12,"x":12,"y":4},"datasource":{"type":"prometheus","uid":"mimir"},"targets":[{"expr":"sum(node_memory_MemTotal_bytes{environment=~\"$environment\",cluster=~\"$cluster\"} - node_memory_MemAvailable_bytes{environment=~\"$environment\",cluster=~\"$cluster\"}) by (cluster)","legendFormat":"{{cluster}}","refId":"A"}]}
