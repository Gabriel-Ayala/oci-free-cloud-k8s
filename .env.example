# Copy this file to .env. Never commit .env.
OCI_REGION=eu-frankfurt-1
OCI_CONFIG_FILE=/absolute/path/to/.oci/config
OCI_CONFIG_PROFILE=DEFAULT
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..xxxxx

# These are consumed by OpenTofu automatically.
TF_VAR_kubernetes_version=v1.33.1
TF_VAR_ssh_public_key=ssh-ed25519 AAAA...

# Optional for the full profile. The minimal profile does not need them.
# TF_VAR_vault_id=ocid1.vault.oc1...
# TF_VAR_github_app_id=123456
# TF_VAR_github_app_installation_id=12345678
# TF_VAR_github_app_pem='-----BEGIN PRIVATE KEY-----...'
# TF_VAR_gh_token=github_pat_...
